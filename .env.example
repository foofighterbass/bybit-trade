# ── Bybit API ─────────────────────────────────────────────────────────────────
# Demo: получить на https://testnet.bybit.com → Account → API Management
# Real: получить на https://www.bybit.com → Account → API Management
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true   # true = demo, false = реальные деньги

# ── База данных ───────────────────────────────────────────────────────────────
# Оставь по умолчанию если используешь docker-compose (контейнер db)
DATABASE_URL=postgresql://bot:botpass@db:5432/botdb

# ── Риск (дефолты, переопределяются в strategies.json) ───────────────────────
MAX_DAILY_LOSS_PCT=5    # % от capital_usdt стратегии
MAX_DRAWDOWN_PCT=20     # % просадки виртуального баланса

# ── Runner ────────────────────────────────────────────────────────────────────
POLL_INTERVAL=30        # секунд между проверками ордеров
