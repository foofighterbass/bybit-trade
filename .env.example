# ── Bybit API ─────────────────────────────────────────────────────────────────
# Demo: получить на https://testnet.bybit.com → Account → API Management
# Real: получить на https://www.bybit.com → Account → API Management
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true   # true = demo, false = реальные деньги

# ── Grid стратегия ────────────────────────────────────────────────────────────
GRID_SYMBOL=BTCUSDT
GRID_LEVELS=5          # кол-во ордеров с каждой стороны от цены
GRID_SPACING_PCT=0.5   # % расстояния между уровнями
GRID_QTY=0.001         # объём каждого ордера (в BTC для BTCUSDT)

# ── Риск-менеджмент ───────────────────────────────────────────────────────────
MAX_DAILY_LOSS_PCT=5    # бот останавливается если дневной убыток > 5%
MAX_DRAWDOWN_PCT=20     # бот останавливается если просадка > 20%

# ── Telegram-алерты ───────────────────────────────────────────────────────────
# Создать бота: https://t.me/BotFather → /newbot
# Узнать chat_id: написать боту, затем открыть
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Runner ────────────────────────────────────────────────────────────────────
POLL_INTERVAL=30   # секунд между проверками ордеров
